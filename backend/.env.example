# ---- Backend (Spring Boot) environment ----
# Used in production (Cloud Run). Copy to .env for local non-Docker runs if desired.

# Activate the production profile (MySQL/TiDB). Local dev uses "local" (H2) by default.
SPRING_PROFILES_ACTIVE=prod

# TiDB Cloud Serverless connection (MySQL compatible, requires TLS).
# Get host/user from the TiDB Cloud console "Connect" dialog.
# Make sure the database (e.g. "medicine") exists in the cluster first.
SPRING_DATASOURCE_URL=jdbc:mysql://gateway01.<region>.prod.aws.tidbcloud.com:4000/medicine?sslMode=VERIFY_IDENTITY&enabledTLSProtocols=TLSv1.2,TLSv1.3
SPRING_DATASOURCE_USERNAME=<prefix>.root
SPRING_DATASOURCE_PASSWORD=<your-password>

# Shared HS256 secret used to verify JWTs minted by the Next.js BFF.
# MUST match the frontend's AUTH_SHARED_SECRET. In Cloud Run this comes from
# Secret Manager (auth-shared-secret); locally it defaults to a dev value.
AUTH_SHARED_SECRET=<same-value-as-frontend>

# Comma-separated allowed origins for CORS. Set to your Vercel domain.
# (Not strictly required because the frontend proxies same-origin via rewrites,
#  but useful if you ever call the backend directly from the browser.)
APP_CORS_ALLOWED_ORIGINS=https://<your-app>.vercel.app

# Cloud Run sets PORT automatically; no need to set it manually.
